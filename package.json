{
  "name": "campus-hustle",
  "version": "1.0.0",
  "description": "Campus Hustle - Student marketplace for Rivers State University. Earn. Hire. Grow.",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "node src/database/migrate.js && node src/database/seed.js && node --watch src/server.js",
    "start": "node src/database/migrate.js && node src/server.js",
    "migrate": "node src/database/migrate.js",
    "seed": "node src/database/seed.js",
    "reset-db": "node src/database/migrate.js --force && node src/database/seed.js"
  },
  "keywords": ["marketplace", "students", "rivers-state-university", "fastify"],
  "author": "Campus Hustle",
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/static": "^7.0.4",
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^11.3.0",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "fastify-plugin": "^4.5.1"
  },
  "devDependencies": {
    "pino-pretty": "^11.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
