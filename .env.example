# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_in_production_min_32_chars
JWT_EXPIRES_IN=7d

# Database
DATABASE_PATH=./data/campus_hustle.db

# Uploads
UPLOAD_DIR=./public/assets/uploads/profiles
MAX_UPLOAD_SIZE_MB=5

# CORS
CORS_ORIGIN=*

# Seed admin account (created by npm run seed)
ADMIN_EMAIL=admin@campushustle.ng
ADMIN_PASSWORD=Admin@12345
ADMIN_NAME=Campus Hustle Admin
